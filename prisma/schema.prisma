generator client {
  provider = "prisma-client-js"
  output   = "../apps/api/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanType {
  TRIAL
  BASIC
  PRO
  ENTERPRISE
}

enum PlanStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

// Un negocio = un salón/barbería/spa registrado en GlowManager
model Business {
  id                  String     @id @default(cuid())
  name                String     @default("")
  type                String     @default("")
  ruc                 String?
  logoUrl             String?
  phone               String?
  address             String?
  timezone            String     @default("America/Lima")
  slotMinutes         Int        @default(30)
  cancellationHours   Int        @default(24)
  reschedulingHours  Int        @default(12)
  operatingDays       String[]   @default(["Mon","Tue","Wed","Thu","Fri"])
  openTime            String     @default("09:00")
  closeTime           String     @default("18:00")
  // Plan y suscripción
  plan                PlanType   @default(TRIAL)
  planStatus          PlanStatus @default(ACTIVE)
  planExpiresAt       DateTime?
  trialEndsAt         DateTime?
  // Plantillas WhatsApp (wa.me links manuales)
  waTplConfirmation   String?
  waTplReminder       String?
  waTplPayment        String?
  reminderEnabled     Boolean  @default(false)
  reminder2hEnabled   Boolean  @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  users          User[]
  clients        Client[]
  collaborators  Collaborator[]
  services       Service[]
  packages       Package[]
  appointments   Appointment[]
}

// Super administrador de la plataforma GlowManager
model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Un usuario pertenece a un negocio y puede ser dueño o colaborador
model User {
  id                     String        @id @default(cuid())
  email                  String        @unique
  password               String
  name                   String
  lastName               String?
  dni                    String?
  role                   Role          @default(OWNER)
  emailVerified          Boolean       @default(false)
  emailVerificationToken String?       @unique
  passwordResetToken     String?       @unique
  passwordResetExpires   DateTime?
  // Se incrementa al resetear contraseña / cerrar sesión global para invalidar
  // JWTs previos (auditoría 1.5). El token lleva este valor y requireAuth lo compara.
  tokenVersion           Int           @default(0)
  businessId             String
  business               Business      @relation(fields: [businessId], references: [id])
  collaboratorId         String?       @unique
  collaborator           Collaborator? @relation(fields: [collaboratorId], references: [id])
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

enum Role {
  OWNER
  COLLABORATOR
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

// Una cita conecta cliente, colaborador y servicio en un horario específico
model Appointment {
  id             String            @id @default(cuid())
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(PENDING)
  price          Decimal           @db.Decimal(10,2)
  notes          String?
  tipPercent     Float             @default(0)
  paidAmount     Decimal?          @db.Decimal(10,2)
  paymentMethod  String?
  depositAmount  Decimal?          @db.Decimal(10,2)
  origin            String?   @default("walkin")
  reminderSentAt    DateTime?
  reminder2hSentAt  DateTime?
  businessId     String
  clientId       String
  collaboratorId String
  serviceId      String
  business       Business          @relation(fields: [businessId], references: [id])
  client         Client            @relation(fields: [clientId], references: [id])
  collaborator   Collaborator      @relation(fields: [collaboratorId], references: [id])
  service        Service           @relation(fields: [serviceId], references: [id])
  events         AppointmentEvent[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

// Historial de eventos de una cita (creación, cambios de estado, pagos, etc.)
model AppointmentEvent {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  type          String      // CREATED | STATUS_CHANGED | DEPOSIT_REGISTERED | PAYMENT_REGISTERED | NOTE_ADDED
  description   String
  createdAt     DateTime    @default(now())
}

// Un paquete agrupa varios servicios con precio especial
model Package {
  id          String           @id @default(cuid())
  name        String
  description String?
  price       Decimal          @db.Decimal(10,2)
  isActive    Boolean          @default(true)
  businessId  String
  business    Business         @relation(fields: [businessId], references: [id])
  services    PackageService[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// Tabla de unión Package ↔ Service (N:M)
model PackageService {
  id        String  @id @default(cuid())
  packageId String
  serviceId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id])

  @@unique([packageId, serviceId])
}

// Un servicio es una prestación del catálogo del negocio
model Service {
  id            String   @id @default(cuid())
  name          String
  description   String?
  category      String
  durationMin   Int
  bufferMinutes  Int      @default(0)
  maxConcurrent  Int?
  price          Decimal  @db.Decimal(10,2)
  color         String   @default("#3B82F6")
  isActive      Boolean  @default(true)
  businessId    String
  business     Business         @relation(fields: [businessId], references: [id])
  appointments Appointment[]
  packages     PackageService[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

// Un colaborador es miembro del equipo del negocio
model Collaborator {
  id               String   @id @default(cuid())
  name             String
  lastName         String?
  role             String
  specialties      String[]
  isActive         Boolean  @default(true)
  performsServices Boolean  @default(true)
  avatarUrl        String?
  schedule         Json?
  documentType     String?
  documentNumber   String?
  phone            String?
  businessId       String
  business         Business      @relation(fields: [businessId], references: [id])
  appointments     Appointment[]
  user             User?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

// Un cliente pertenece a un negocio y acumula visitas y gasto a lo largo del tiempo
model Client {
  id           String   @id @default(cuid())
  name         String
  lastName     String?
  dni          String?
  phone        String?
  email        String?
  notes        String?
  totalVisits  Int      @default(0)
  totalSpent   Decimal  @db.Decimal(10,2) @default(0)
  businessId   String
  business     Business      @relation(fields: [businessId], references: [id])
  appointments Appointment[]
  records      ClientRecord[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// Ficha técnica por cliente — historial de tratamientos, fórmulas, alergias
model ClientRecord {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date         DateTime @default(now())
  treatment    String
  colorFormula String?
  allergies    String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
